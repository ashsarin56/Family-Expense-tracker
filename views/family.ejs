<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>my family</title>
</head>
<body>
    <h1><%=family.name%></h1>
    <p>invite code: <strong><%=family.invite_code%></strong> (share this with family members)</p>
    <hr>
    <h2>members</h2>
    <table border="1" cellpadding="8">
        <tr>
            <th>name</th>
            <th>email</th>
            <th>role</th>
        </tr>
        <%members.forEach(function(member){%>
        <tr>
            <td><%=member.name%></td>
            <td><%=member.email%></td>
            <td><%=member.role%></td>
        </tr>
        <%})%>
    </table>
    <br>
    <a href="/dashboard">back to dashboard</a>
</body>
</html>
