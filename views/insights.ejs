<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monthly Insights</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <a href="/dashboard" class="brand">💰 FamExpense</a>
        <nav>
            <a href="/dashboard">Dashboard</a>
            <a href="/family">Family</a>
            <a href="/categories">Categories</a>
            <a href="/expenses">Expenses</a>
            <a href="/insights" class="active">Insights</a>
            <a href="/auth/logout">Logout</a>
        </nav>
    </div>
    <div class="container">
        <div class="card">
            <h1>Monthly Insights — <%=month%>/<%=year%></h1>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value">₹<%=totalSpent%></div>
                    <div class="stat-label">Total Spent</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%=summary.length%></div>
                    <div class="stat-label">Categories Used</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%=expenses.length%></div>
                    <div class="stat-label">Transactions</div>
                </div>
            </div>
        </div>
        <%if(summary.length>0){%>
        <div class="card">
            <h2>Category-wise Breakdown</h2>
            <div class="table-wrapper">
                <table>
                    <tr>
                        <th>Category</th>
                        <th>Total (₹)</th>
                        <th>Transactions</th>
                    </tr>
                    <%summary.forEach(function(s){%>
                    <tr>
                        <td><%=s.category_name%></td>
                        <td><strong>₹<%=s.total%></strong></td>
                        <td><%=s.count%></td>
                    </tr>
                    <%})%>
                </table>
            </div>
        </div>
        <div class="card">
            <h2>Member-wise Spending</h2>
            <div class="table-wrapper">
                <table>
                    <tr>
                        <th>Member</th>
                        <th>Total (₹)</th>
                        <th>Transactions</th>
                    </tr>
                    <%userWise.forEach(function(u){%>
                    <tr>
                        <td><%=u.user_name%></td>
                        <td><strong>₹<%=u.total%></strong></td>
                        <td><%=u.count%></td>
                    </tr>
                    <%})%>
                </table>
            </div>
        </div>
        <%}%>
        <div class="card">
            <h2>🤖 AI Financial Advice</h2>
            <%if(aiInsight){%>
                <div class="ai-box">
                    <p><%- aiInsight.replace(/\n/g,'<br>') %></p>
                </div>
            <%}else{%>
                <p>Get personalized tips based on your spending patterns.</p>
                <a href="/insights/ai?month=<%=month%>&year=<%=year%>" class="btn btn-primary mt-20">Generate AI Advice →</a>
            <%}%>
        </div>
        <a href="/dashboard" class="link">← Back to Dashboard</a>
    </div>
</body>
</html>
